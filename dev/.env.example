# Copy to .env — SQLite file lives in the project root; delete it to reset data.
DATABASE_URI=file:./payload-theme-playground.db
PAYLOAD_SECRET=change-me-to-any-long-random-string

# Public read-only demo mode: set to 'true' to block every create/update/delete
# at the access layer while keeping the whole panel browsable (see DEPLOY.md).
# DEMO_MODE=true
